generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Attachmenst {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type") @db.VarChar(20)
  fileName  String   @map("file_name") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  messages  Message  @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("attachmenst")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Avatar {
  id         String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(10)
  userId     String?  @map("user_id") @db.Uuid
  chatId     String?  @map("chat_id") @db.Uuid
  avatarUrl  String   @map("avatar_url")
  isPrimary  Boolean  @default(true) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  chats      Chat?    @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("avatars")
}

model ChannelSetting {
  chatId      String  @id @map("chat_id") @db.Uuid
  description String? @db.VarChar(300)
  isPrivate   Boolean @default(true) @map("is_private")
  chats       Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("channel_settings")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ChatParticipant {
  chatId              String   @map("chat_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  role                String   @default("member") @db.VarChar(20)
  joinedAt            DateTime @default(now()) @map("joined_at") @db.Timestamp(6)
  lastReadMessageTime DateTime @default(now()) @map("last_read_message_time") @db.Timestamp(6)
  chat                Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([chatId, userId])
  @@map("chat_participants")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Chat {
  id               String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  type             String            @default("private") @db.VarChar(20)
  title            String?           @db.VarChar(50)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamp(6)
  avatars          Avatar[]
  channelSettings  ChannelSetting?
  chatParticipants ChatParticipant[]
  invite_links     InviteLink[]
  messages         Message[]
  reports          Report[]

  @@map("chats")
}

model InviteLink {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_invite_links_chat")

  @@map("invite_links")
}

model MessageReaction {
  id        String  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  messageId String  @map("message_id") @db.Uuid
  userId    String? @map("user_id") @db.Uuid
  emoji     String  @db.VarChar(10)
  messages  Message @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User?   @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@map("message_reactions")
}

model Message {
  id               String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  chatId           String?           @map("chat_id") @db.Uuid
  userId           String?           @map("user_id") @db.Uuid
  type             String            @default("text")
  text             String?
  replyToId        String?           @map("reply_to_id") @db.Uuid
  isDeleted        Boolean           @default(false) @map("is_deleted")
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  editedAt         DateTime          @default(now()) @map("edited_at") @db.Timestamp(6)
  attachments      Attachmenst[]
  messageReactions MessageReaction[]
  chat             Chat?             @relation(fields: [chatId], references: [id], onUpdate: NoAction)
  user             User?             @relation(fields: [userId], references: [id], onUpdate: NoAction)

  replyTo Message?  @relation("ReplyRelation", fields: [replyToId], references: [id], onUpdate: NoAction)
  replies Message[] @relation("ReplyRelation")

  @@map("messages")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Report {
  id     String  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  chatId String  @map("chat_id") @db.Uuid
  userId String? @map("user_id") @db.Uuid
  reason String
  status String  @db.VarChar(10)
  chat   Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user   User?   @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@map("reports")
}

model Session {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  token       String   @unique @db.VarChar(255)
  tokenType   String   @map("token_type") @db.VarChar(15)
  fingerprint String   @db.VarChar(255)
  expiresAt   DateTime @map("expires_at") @db.Timestamp(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  users       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sessions_user")

  @@map("sessions")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model User {
  id               String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  globalRole       String            @default("user") @map("global_role") @db.VarChar(20)
  username         String            @unique @db.VarChar(30)
  firstName        String            @map("first_name") @db.VarChar(30)
  lastName         String?           @map("last_name") @db.VarChar(30)
  email            String            @unique @db.VarChar(100)
  passwordHash     String            @map("password_hash") @db.VarChar(255)
  bio              String?           @db.VarChar(100)
  lastSeen         DateTime          @map("last_seen") @db.Timestamp(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamp(6)
  isBanned         Boolean           @default(false) @map("is_banned")
  avatars          Avatar[]
  chatParticipants ChatParticipant[]
  messageReactions MessageReaction[]
  messages         Message[]
  reports          Report[]
  sessions         Session[]
  userBlocks       UserBlock[]       @relation("UserBlocks")
  userBlockedBy    UserBlock[]       @relation("UserBlockedBy")

  @@map("users")
}

model UserBlock {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  blocker   User?    @relation("UserBlocks", fields: [blockerId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  blocked   User?    @relation("UserBlockedBy", fields: [blockedId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@id([blockerId, blockedId])
  @@map("users_blocks")
}
